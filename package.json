{
  "name": "tfsec",
  "displayName": "tfsec",
  "publisher": "tfsec",
  "description": "Tfsec integration for Visual Studio Code",
  "version": "1.1.12",
  "engines": {
    "vscode": "^1.54.0"
  },
  "icon": "tfsec.png",
  "categories": [
    "Other",
    "Linters"
  ],
  "languages": [
    {
      "id": "terraform",
      "extensions": [
        ".tf",
        ".tf.json"
      ],
      "aliases": [
        "Terraform"
      ]
    }
  ],
  "activationEvents": [
    "onView:tfsec.issueview",
    "onLanguage:terraform",
    "onCommand:tfsec.run",
    "onCommand:tfsec.refresh"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "tfsec",
      "properties": {
        "tfsec.binaryPath": {
          "type": "string",
          "default": "tfsec",
          "description": "Path to tfsec if not already on the PATH"
        },
        "tfsec.ignoreDownloadedModules": {
          "type": "boolean",
          "default": "true",
          "description": "Don't include results from downloaded modules. (Still scanned, just not included in the results)"
        },
        "tfsec.fullDepthSearch": {
          "type": "boolean",
          "default": "true",
          "description": "Scan all terraform in the workspace. This will start at the top and add all terraform files into the model"
        },
        "tfsec.resolveIgnoreCodes": {
          "type": "boolean",
          "default": "true",
          "description": "Add the description for ignore codes inline with the code"
        },
        "tfsec.runOnIgnore": {
          "type": "boolean",
          "default": "true",
          "description": "Automatically rerun tfsec when a check failure is ignored"
        }
      }
    },
    "commands": [
      {
        "command": "tfsec.run",
        "title": "tfsec: Run tfsec against workspace",
        "icon": {
          "light": "resources/light/run.svg",
          "dark": "resources/dark/run.svg"
        }
      },
      {
        "command": "tfsec.refresh",
        "title": "tfsec: Refresh the issue list",
        "icon": {
          "light": "resources/light/refresh.svg",
          "dark": "resources/dark/refresh.svg"
        }
      },
      {
        "command": "tfsec.updatebinary",
        "title": "tfsec: Download the latest version of tfsec",
        "icon": {
          "light": "resources/light/download.svg",
          "dark": "resources/dark/download.svg"
        }
      },
      {
        "command": "tfsec.ignore",
        "title": "Ignore this issue"
      },
      {
        "command": "tfsec.openissue",
        "title": "Open as a git issue"
      },
      {
        "command": "tfsec.version",
        "title": "tfsec: Get the current version of tfsec"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tfsec",
          "title": "tfsec",
          "icon": "media/tfsec.svg"
        }
      ]
    },
    "views": {
      "tfsec": [
        {
          "id": "tfsec.issueview",
          "name": "Issue Explorer",
          "icon": "media/tfsec.svg",
          "contextualTitle": "Issue Explorer"
        },
        {
          "id": "tfsec.helpview",
          "name": "Check Help",
          "type": "webview",
          "contextualTitle": "Issue Help",
          "visibility": "collapsed"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "tfsec.issueview",
        "contents": "No issues are found.\n[Run tfsec now](command:tfsec.run)"
      },
      {
        "view": "tfsec.helpview",
        "contents": "No check selected. Run tfsec and choose a failed check from the explorer"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "tfsec.ignore",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "tfsec.run",
          "when": "view == tfsec.issueview",
          "group": "navigation@1"
        },
        {
          "command": "tfsec.refresh",
          "when": "view == tfsec.issueview",
          "group": "navigation@2"
        },
        {
          "command": "tfsec.updatebinary",
          "when": "view == tfsec.issueview",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "tfsec.ignore",
          "when": "view == tfsec.issueview && viewItem == TFSEC_FILE_LOCATION"
        },
        {
          "command": "tfsec.openissue",
          "when": "view == tfsec.issueview && viewItem == TFSEC_FILE_LOCATION && tfsec.isgit"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "mocha -r ts-node/register src/test/*.ts"
  },
  "devDependencies": {
    "@types/chai": "^4.2.21",
    "@types/glob": "^7.1.3",
    "@types/mocha": "^8.2.3",
    "@types/node": "^12.20.13",
    "@types/semver": "^7.3.6",
    "@types/vscode": "^1.58.0",
    "@typescript-eslint/eslint-plugin": "^4.25.0",
    "@typescript-eslint/parser": "^4.25.0",
    "chai": "^4.3.4",
    "eslint": "^7.27.0",
    "glob": "^7.1.7",
    "mocha": "^8.4.0",
    "ts-node": "^10.1.0",
    "typescript": "^4.3.5",
    "vscode": "^1.1.37",
    "vscode-test": "^1.5.0"
  },
  "repository": {
    "url": "https://github.com/aquasecurity/vscode-tfsec"
  },
  "dependencies": {
    "@types/github-url-from-git": "^1.5.1",
    "@types/parse-git-config": "^3.0.1",
    "github-url-from-git": "^1.5.0",
    "parse-git-config": "^3.0.0",
    "rewire": "^5.0.0",
    "semver": "^7.3.5",
    "typescipt": "^1.0.0",
    "vscode": "^1.1.37"
  }
}